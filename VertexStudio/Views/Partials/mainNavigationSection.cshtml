@using Umbraco.Cms.Core.Models.PublishedContent
@using Umbraco.Cms.Web.Common.PublishedModels
@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    var siteSettings = Umbraco.ContentAtRoot().DescendantsOrSelf<SiteSettings>().FirstOrDefault();

    var searchTerm = Context.Request.Query["q"].ToString();
    var hasSearched = !string.IsNullOrWhiteSpace(searchTerm);

    var searchResults = hasSearched
        ? Umbraco.ContentAtRoot()
            .DescendantsOrSelf()
            .Where(x => x.IsVisible() && !string.IsNullOrEmpty(x.Name) && x.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase))
            .Take(8)
            .ToList()
        : new List<IPublishedContent>();
}

<div class="menu-sticked">
    <header>
        <div class="container">
            <div class="row align-items-center">
                <button type="button"
                        class="nav-toggle d-lg-none"
                        aria-label="Abrir menu"
                        aria-expanded="false"
                        aria-controls="mainNavMenu">
                    <span class="nav-toggle__bar"></span>
                    <span class="nav-toggle__bar"></span>
                    <span class="nav-toggle__bar"></span>
                </button>

                <nav class="w-100">
                    <div class="nav-menu" id="mainNavMenu">
                        <ul>
                            @if (siteSettings is not null)
                            {
                                @await Html.GetBlockGridHtmlAsync(siteSettings, "mainNavigationSection")
                            }

                            <li class="nav-item search-item d-flex align-items-center">
                                <button type="button"
                                        class="search-toggle"
                                        aria-label="Pesquisar"
                                        aria-expanded="@(hasSearched ? "true" : "false")"
                                        aria-controls="siteSearchBox">
                                    <i class="fas fa-search"></i>
                                </button>
                            </li>
                        </ul>
                    </div>
                </nav>
            </div>

            <div class="site-search @(hasSearched ? "site-search--open" : "")" id="siteSearchBox">
                <form class="site-search__form" method="get" action="">
                    <input type="search"
                           name="q"
                           class="site-search__input"
                           placeholder="Pesquisar no site..."
                           value="@searchTerm"
                           autocomplete="off" />
                    <button type="submit" class="site-search__submit" aria-label="Pesquisar">
                        <i class="fas fa-search"></i>
                    </button>
                </form>

                @if (hasSearched)
                {
                    <div class="site-search__results">
                        @if (searchResults.Any())
                        {
                            <ul>
                                @foreach (var result in searchResults)
                                {
                                    <li>
                                        <a href="@result.Url()">@result.Name</a>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="site-search__empty">Sem resultados para "@searchTerm".</p>
                        }
                    </div>
                }
            </div>
        </div>
    </header>
</div>

@* Estilo autónomo para o menu e a pesquisa, para não depender de outros
   ficheiros CSS do projeto que possam estar desligados. *@
<style>
    .menu-sticked header {
        padding: 16px 0;
    }

    .menu-sticked .nav-menu ul {
        display: flex;
        align-items: center;
        gap: 24px;
        list-style: none;
        margin: 0;
        padding: 0;
    }

    .menu-sticked .nav-link {
        color: inherit;
        text-decoration: none;
        font-weight: 600;
    }

    .search-toggle {
        border: none;
        background: transparent;
        cursor: pointer;
        font-size: 1.1rem;
        padding: 6px;
        display: flex;
        align-items: center;
    }

    .site-search {
        max-height: 0;
        overflow: hidden;
        transition: max-height 200ms ease;
    }

    .site-search--open {
        max-height: 320px;
    }

    .site-search__form {
        display: flex;
        gap: 8px;
        padding: 12px 0;
    }

    .site-search__input {
        flex: 1;
        padding: 10px 14px;
        border-radius: 4px;
        border: 1px solid #ccc;
    }

    .site-search__submit {
        border: none;
        border-radius: 4px;
        background-color: #ffcc00;
        padding: 0 16px;
        cursor: pointer;
    }

    .site-search__results ul {
        list-style: none;
        margin: 0 0 12px;
        padding: 0;
    }

    .site-search__results li + li {
        border-top: 1px solid #eee;
    }

    .site-search__results a {
        display: block;
        padding: 8px 4px;
        text-decoration: none;
        color: inherit;
    }

    .nav-toggle {
        border: none;
        background: transparent;
        display: flex;
        flex-direction: column;
        gap: 4px;
        cursor: pointer;
    }

    .nav-toggle__bar {
        width: 24px;
        height: 2px;
        background-color: currentColor;
    }

    @@media (max-width: 991.98px) {
        .menu-sticked .nav-menu {
            display: none;
        }

        .menu-sticked .nav-menu--open {
            display: block;
        }

        .menu-sticked .nav-menu ul {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

@* O botão "hamburger" abre/fecha o menu em mobile, e o botão de pesquisa
   abre/fecha a caixa de pesquisa. Se a pesquisa já tiver resultados (porque
   veio de um "?q=" no URL), a caixa começa aberta. *@
<script>
    document.addEventListener("DOMContentLoaded", function () {
        var toggle = document.querySelector(".nav-toggle");
        var menu = document.getElementById("mainNavMenu");

        if (toggle && menu) {
            toggle.addEventListener("click", function () {
                var isOpen = menu.classList.toggle("nav-menu--open");
                toggle.classList.toggle("is-open", isOpen);
                toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
            });
        }

        var searchToggle = document.querySelector(".search-toggle");
        var searchBox = document.getElementById("siteSearchBox");

        if (searchToggle && searchBox) {
            searchToggle.addEventListener("click", function () {
                var isOpen = searchBox.classList.toggle("site-search--open");
                searchToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
                if (isOpen) {
                    var input = searchBox.querySelector(".site-search__input");
                    if (input) { input.focus(); }
                }
            });
        }
    });
</script>
