<!-- Modal Contact -->
<div class="modal fade ModalContact" tabindex="-1" role="dialog" aria-hidden="true">
    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><i class="fas fa-times"></i></button>
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <!--Header-->
            <div class="modal-header">
                <h3 class="modal-title">Almost There!</h3>
            </div>
            <!--Header-->
            <!--Body-->
            <div class="modal-body">
                <form>
                    <div class="form-row mt-3">
                        <!--Name-->
                        <div class="form-group col-md-6">
                            <label for="inputFullName">Full Name</label>
                            <input type="text" class="form-control form-control-lg" id="inputFullName" placeholder="Full name">
                        </div>
                        <!--Name-->
                        <!--Email-->
                        <div class="form-group col-md-6">
                            <label for="inputEmail">Email</label>
                            <input type="email" class="form-control form-control-lg" id="inputEmail" placeholder="Email">
                        </div>
                        <!--Email-->
                    </div>

                    <!--Address-->
                    <div class="form-group mt-3">
                        <label for="inputAddress">Address</label>
                        <input type="text" class="form-control form-control-lg" id="inputAddress" placeholder="1234 Main St">
                    </div>
                    <!--Address-->

                    <div class="form-row mt-4">
                        <!--City-->
                        <div class="form-group col-md-6">
                            <label for="inputCity">City</label>
                            <input type="text" class="form-control form-control-lg" id="inputCity">
                        </div>
                        <!--City-->
                        <!--State-->
                        <div class="form-group col-md-4">
                            <label for="inputState">State</label>
                            <select id="inputState" class="form-control form-control-lg">
                                <option selected>Choose...</option>
                                <option>...</option>
                            </select>
                        </div>
                        <!--State-->
                        <!--Zip-->
                        <div class="form-group col-md-2">
                            <label for="inputZip">Zip</label>
                            <input type="text" class="form-control form-control-lg" id="inputZip">
                        </div>
                        <!--Zip-->
                    </div>

                    <div class="form-group mt-3">
                        <label for="description_help">¿What can we Help you?</label>
                        <textarea class="form-control" id="description_help" rows="5"></textarea>
                    </div>

                    <div class="form-group mt-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="gridCheck">
                            <label class="form-check-label" for="gridCheck">
                                Subscribe to our Newsletter
                            </label>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-outline-primary btn-lg mt-4"><span>Contact Us</span></button>
                </form>
            </div>
            <!--Body-->
        </div>
    </div>
</div>
<!-- Modal Contact -->
<!-- Modal Gallery -->
<div class="modal fade ModalGallery" tabindex="-1" role="dialog" aria-hidden="true">
    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><i class="fas fa-times"></i></button>
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-body">
                <figure>
                    <!--Carousel Images-->
                    <div id="carouselGalleryWorks" class="carousel slide" data-ride="carousel">
                        <div class="carousel-inner">
                            <div class="carousel-item active">
                                <img class="d-block w-100" src="https://via.placeholder.com/1100x510" alt="First slide">
                            </div>
                            <div class="carousel-item">
                                <img class="d-block w-100" src="https://via.placeholder.com/1100x510" alt="Second slide">
                            </div>
                        </div>
                        <!--Carousel Images-->
                        <!--Carousel Navs-->
                        <a class="carousel-control-prev" href="#carouselGalleryWorks" role="button" data-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                            <span class="sr-only">Previous</span>
                        </a>
                        <a class="carousel-control-next" href="#carouselGalleryWorks" role="button" data-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true"></span>
                            <span class="sr-only">Next</span>
                        </a>
                        <!--Carousel Navs-->
                    </div>

                    <figcaption class="mt-3">
                        <h3 class="mt-4">Project Name</h3>
                        <hr class="light-color">
                        <p>Photography is the art, application and practice of creating durable images by recording light or other electromagnetic radiation, either electronically by means of an image sensor, or chemically by means of a light-sensitive material such as photographic film.</p>
                    </figcaption>
                </figure>
            </div>
        </div>
    </div>
</div>
<!-- Modal Gallery -->
